{
  "manifest_version": 3,
  "name": "Tab Exporter",
  "version": "1.1.0",
  "description": "Export tabs to TXT, MD, and PDF with masking",
  "permissions": [
    "contextMenus",
    "tabs",
    "downloads",
    "offscreen",
    "scripting"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "dist/background.js",
    "type": "module"
  },
  "minimum_chrome_version": "109"
}
